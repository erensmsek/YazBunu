# Groq API anahtarı — API modunun (varsayılan) tek gereksinimi.
# Normalde uygulama içindeki Ayarlar ekranından girilir (tarayıcıda saklanır);
# buraya yazmak yalnızca sunucu tarafı bir yedektir (isteğe bağlı).
# Ücretsiz al: https://console.groq.com/keys
GROQ_API_KEY=

# HF_TOKEN — yalnızca geliştirici/yedek: özet/polish için Groq yerine HF Inference
# API (llm.py) kullanılırsa gerekir. Son kullanıcı için gerekli değildir.
HF_TOKEN=
